                                        type: "POST",
                                        url: "@Url.Action("AccountClosureRequest", "Modification")",
                                        data: formData,
                                        processData: false,
                                        contentType: false,
                                        success: function (response) {
                                            hideLoader();
                                            if (response.Status == "success") {
                                                if (response.Doc_Id != 'NA' && response.Doc_Id != 'errorattachment') {
                                                    esignDocument(response.Doc_Id, response.Email);
                                                }
                                                else if (response.Doc_Id === 'errorattachment') {
                                                    alert('Some of your attached document is password protected. We cannot process such documents. Please upload it agian by removing password protection and continue the process.')
                                                }
                                            }
                                            else {
                                                alert("you already requested for Account Closure");
                                            }
                                        },
                                        error: function (response) {
                                            hideLoader();
                                            alert('Something went wrong while E-Signing the document');
                                        }
                                    });
    }
      function esignDocument(doc_id, identifier) {
       // alert(doc_id);

        var options = {
            environment: "production",
            callback: function (response) {
               // alert(response);
                var docId = response.digio_doc_id;
                if (response.error_code != undefined)
                    alert("Something went wrong,cannot process the signing process");
                else {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("saveDocument","Modification")",
                        data: { docId: docId },
                        success: function (response) {
                            if (response == "success") {
                                alert("Your request submitted successfully");
                                window.location.href = "@Url.Action("ClientModification","Modification")";
                            }
                        },
                        error: function (response) {
                            //alert(JSON.stringify(response));
                            alert('Something went wrong while E-Signing the document');
                        }
                    });
                }
            },
            logo: "",
            method: ""
        };
        options.method = 'otp';
        var digio = new Digio(options);
        //alert(digio);
        digio.init();
       // alert('init invoked');
        digio.submit(doc_id, identifier);
    }

    function esignDocumentClick() {

        var LogoPath;
        LogoPath = document.getElementById("LogoPath").value;

        var AuthenticationType;
        var AuthenticationType = document.getElementById("AuthenticationType").value;

        if (AuthenticationType == "OTP") {
            AuthenticationType = "otp"
        } else {
            AuthenticationType = "biometric"

        };

        var DocumentID;
        var DocumentID = document.getElementById("DocumentID").value;


        var Identifier;
        var Identifier = document.getElementById("Identifier").value;

        var options = {

            "environment": "stage",
            "callback": function (t) {
                if (t.error_code != undefined)
                    alert("failed to sign with error :" + t.message);
                else
                    alert("sign successful for " + t.digio_doc_id);
                window.location.replace("success.html");
            },
            "logo": "",
            "method": "otp"
        };

        options.logo = LogoPath;
        options.method = AuthenticationType;

        var digio = new Digio(options);
        digio.init();
        digio.esign(DocumentID, Identifier);

    }
