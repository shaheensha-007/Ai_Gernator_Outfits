
@{
    ViewBag.Title = "ClientModification";
    Layout = "~/Views/Shared/_ClientModificationLayout.cshtml";
}
<style>
    #txtIFSC {
        text-transform: uppercase;
    }
</style>
<script src="~/Scripts/digio_vertex.js"></script>
<div class="row">
    <div class="col-md-6 col-lg-6 col-sm-12 offset-md-3 offset-lg-3">
        <!--Mobile Change-->
        <h6 style="text-decoration:underline">Client Modification Requests</h6>
        <section class="change-section" style="margin-top:20px;">
            <div class="row">
                <div class="col-md-12 expandedview">
                    <p class="expanded-p">Change Mobile</p>
                    <a href="#" class="btn btn-info option" id="mobile">
                        <span class="fa fa-plus" style="font-size:30px;color:#ff6a00 !important"></span>
                    </a>
                </div>
                <div class="col-md-12 expanded-content" id="exp-mobile">
                    <div class="row">
                        <div class="col-md-12"><p class="expanded-p-more">Request for Changing Mobile Number</p></div>
                        <div class="col-md-6 col-lg-6 col-sm-12 offst-md-3 offset-lg-3 inline-controls">
                            <input type="number" class="form-control" placeholder="Enter New Mobile Number" id="txtMobile" maxlength="10" required />
                            <a href="#" class="verify" id="mobileverify">Verify </a>
                            <p class="verify-success">Verified</p>
                        </div>
                        <div class="col-md-6 col-lg-6 col-sm-12 offst-md-3 offset-lg-3 inline-controls" id="OTPDiv-mobile" style="display:none !important">
                            <input type="number" class="form-control" placeholder="Enter OTP" id="txtOTP" />
                            <a href="#" class="verify" id="otpverify-mobile">Verify</a>

                        </div>
                        <div class="col-md-12" id="radioOptions" style="display:none !important;text-align:center">

                            <input type="checkbox" name="mobileoption" class="option-radio opt" id="mobile-trade" value="TRADING" /><label class="option-label">Trading</label>
                            <input type="checkbox" name="mobileoption" class="option-radio opt" id="mobile-dp" value="DP" /><label class="option-label">DP</label>
                        </div>
                        <div class="col-md-12" style="text-align:center;display:none" id="divSubmit">
                            <button type="button" class="btn btn-default" id="btnSubmit">Submit Request</button>
                        </div>

                    </div>
                </div>
            </div>
        </section>

        <!--Email-->
        <section class="change-section" style="margin-top:20px;">
            <div class="row">
                <div class="col-md-12 expandedview">
                    <p class="expanded-p">Change Email</p>
                    <a href="#" class="btn btn-info option" id="email">
                        <span class="fa fa-plus" style="font-size:30px;color:#ff6a00 !important"></span>
                    </a>
                </div>
                <div class="col-md-12 expanded-content" id="exp-email">
                    <div class="row">
                        <div class="col-md-12"><p class="expanded-p-more">Request for Changing Email ID</p></div>
                        <div class="col-md-6 col-lg-6 col-sm-12 offst-md-3 offset-lg-3 inline-controls">
                            <input type="email" class="form-control" placeholder="Enter New Email ID" id="txtEmail" required />
                            <a href="#" class="verify" id="emailverify">Verify </a>
                            <p class="verify-success" id="verified-email">Verified</p>
                        </div>
                        <div class="col-md-6 col-lg-6 col-sm-12 offst-md-3 offset-lg-3 inline-controls" id="OTPDiv-email" style="display:none !important">
                            <input type="number" class="form-control" placeholder="Enter OTP" id="txtOTP-email" />
                            <a href="#" class="verify" id="otpverify-email">Verify</a>
                        </div>
                        <div class="col-md-12" id="radioOptions-email" style="display:none !important;text-align:center">
                            <input type="checkbox" name="emailoption" class="option-radio opt" id="email-trade" value="TRADING" /><label class="option-label">Trading</label>
                            <input type="checkbox" class="option-radio opt" name="emailoption" id="email-dp" value="DP" style="margin-left:6px;" /> <label class="option-label">DP</label>
                        </div>
                        <div class="col-md-12" style="text-align:center;display:none" id="divSubmit-email">
                            <button type="button" class="btn btn-default" id="btnSubmit-email">Submit Request</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!--Address-->
        <section class="change-section" style="margin-top:20px;">
            <div class="row">
                <div class="col-md-12 expandedview">
                    <p class="expanded-p">Change Address</p>
                    <a href="#" class="btn btn-info option" id="address">
                        <span class="fa fa-plus" style="font-size:30px;color:#ff6a00 !important"></span>
                    </a>
                </div>
                <div class="col-md-12 expanded-content" id="exp-address">
                    <div class="row">
                        <div class="col-md-12"><p class="expanded-p-more">Request for Changing Address</p></div>
                        <div class="col-md-12 inline-controls-text">
                            <input type="text" id="txtaddress1" class="form-control modif-text" placeholder="Address1" required />
                            <input type="text" id="txtaddress2" class="form-control modif-text" placeholder="Address2" required />
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <input type="text" id="txtcity" class="form-control modif-text" placeholder="City" required />
                            <input type="text" id="txtzipcode" class="form-control modif-text" placeholder="Zip Code" required />
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <input type="text" id="txtstate" class="form-control modif-text" placeholder="State" required />
                            <select class="form-control modif-text" id="country">
                                <option value="India">India</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <select class="form-control modif-text" id="address_proof">
                                <option value="0">-New addresss proof-</option>
                                <option value="Passport">Passport</option>
                                <option value="VoterID">Voter ID</option>
                                <option value="DrivingLicense">Driving License</option>
                                <option value="BankPassbookWithLatestStatement">Bank passbook with latest three month statement</option>
                                <option value="TelephoneBill">Telephone Bill (only Land line)</option>
                                <option value="ElectricityBill">Electricity Bill (not more than 3 month)</option>
                                <option value="Other">Other</option>
                            </select>
                            <input type="file" id="file_addressproof" class="form-control modif-text" placeholder="Address Proof" />
                        </div>
                        <div class="col-md-12" id="radioOptions" style="text-align:center">
                            <input type="checkbox" name="addressoption" class="option-radio opt" id="address-trade" value="TRADING" /><label class="option-label">Trading</label>
                            <input type="checkbox" class="option-radio opt" name="addressoption" id="address-dp" value="DP" style="margin-left:6px;" /> <label class="option-label">DP</label>
                        </div>
                        <div class="col-md-12" style="text-align:center">
                            <button class="btn btn-default" id="btnsubmit_address" type="button">Submit</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!--Bank Info-->
        <section class="change-section" style="margin-top:20px;">
            <div class="row">
                <div class="col-md-12 expandedview">
                    <p class="expanded-p">Change Bank Info</p>
                    <a href="#" class="btn btn-info option" id="bank">
                        <span class="fa fa-plus" style="font-size:30px;color:#ff6a00 !important"></span>
                    </a>
                </div>
                <div class="col-md-12 expanded-content" id="exp-bank">
                    <div class="row">
                        <div class="col-md-12"><p class="expanded-p-more">Request for Changing Bank Details</p></div>
                        <div class="col-md-12 inline-controls-text">
                            <input type="text" id="txtAccountNumber" class="form-control modif-text" placeholder="Account Number" />
                            <input type="text" id="txtIFSC" class="form-control modif-text" placeholder="IFSC" />
                        </div>
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-12 inline-controls-text">
                                    <input type="text" id="txtbankname" class="form-control modif-text" placeholder="Bank Name" disabled />
                                    <input type="text" id="txtmicrCode" class="form-control modif-text" placeholder="MICR" disabled />
                                </div>

                            </div>
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <textarea class="form-control" placeholder="Bank Address" style="width:87% !important" id="txtbankaddress" disabled></textarea>
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <input type="text" id="txtbranchname" class="form-control modif-text" placeholder="Branch Name" disabled />
                            <select class="form-control modif-text" id="accounttype">
                                <option value="0">-Account Type-</option>
                                <option value="current">Current</option>
                                <option value="savings">Savings</option>
                            </select>
                        </div>

                        <div class="col-md-12" id="radioOptions" style="text-align:center;padding:15px">
                            <input type="checkbox" name="bankoption" class="option-radio opt" id="bank-trade" value="TRADING" /><label class="option-label">Trading</label>
                            <input type="checkbox" class="option-radio opt" name="bankoption" id="bank-dp" valus="DP" style="margin-left:6px;" /> <label class="option-label">DP</label>
                        </div>

                        <div class="col-md-12" style="text-align:center">
                            <button class="btn btn-default" id="btnsubmit_bankverify">Verify and Submit</button>
                        </div>
                        <div class="col-md-12 inline-controls-text" id="bankProofDiv" style="display:none;">
                            <div class="row">
                                <div class="col-md-6 inline-controls-text">
                                    <select id="bankproof" class="form-control">
                                        <option value="ChequeLeaf">Cancelled Cheque leaf</option>
                                        <option value="BankStatement">Bank Statement</option>
                                        <option value="PassbookFrontPage">Front page of Passbook</option>
                                    </select>
                                </div>
                                <div class="col-md-6 inline-controls-text">
                                    <input type="file" id="upload_bankproof" class="form-control" placeholder="Bank Proof" />
                                </div>
                                <div class="col-md-12" style="text-align:center;">
                                    <button class="btn btn-default" id="btnsubmit_bank">Submit</button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </section>
        <!--Nomination-->
        <section class="change-section" style="margin-top:20px;">
            <div class="row">
                <div class="col-md-12 expandedview">
                    <p class="expanded-p">Change Nominee</p>
                    <a href="#" class="btn btn-info option" id="nomination">
                        <span class="fa fa-plus" style="font-size:30px;color:#ff6a00 !important"></span>
                    </a>
                </div>
                <div class="col-md-12 expanded-content" id="exp-nomination">
                    <div class="row">
                        <div class="col-md-12"><p class="expanded-p-more">Request for Changing Nominee</p></div>
                        <div class="col-md-12 inline-controls-text">
                            <select class="form-control modif-text" id="nomineeTitle">
                                <option value="Mr.">Mr.</option>
                                <option value="Ms.">Ms.</option>
                            </select>
                            <input type="text" id="txtNomineeName" class="form-control modif-text" placeholder="Name" />
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <textarea class="form-control" placeholder="Nominee Address" id="txtNomineeAddress" style="width:87% !important"></textarea>
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <input type="text" id="txtNomineeDOB" class="form-control modif-text" placeholder="Nominee DOB" onfocus="(this.type='date')" />
                            <input type="text" id="txtNomineeRelation" class="form-control modif-text" placeholder="Relation with Nominee" />

                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <input type="text" id="txtNomineeMobile" class="form-control modif-text" placeholder="Nominee Mobile" />
                            <input type="text" id="txtNomineeEmail" class="form-control modif-text" placeholder="Nominee Email" />
                        </div>
                        <div class="col-md-12 inline-controls-text">
                            <select class="form-control modif-text" id="nomineeProof">
                                <option value="pan">PAN</option>
                                <option value="aadhar">Aadhar</option>
                            </select>
                            <input type="file" id="file_nomineeproof" class="form-control modif-text" placeholder="Nominee Proof" />
                        </div>
                        <div class="col-md-12" id="radioOptions" style="text-align:center">
                            <input type="checkbox" name="nomineeoption" class="option-radio opt" id="nomination-trade" value="TRADING" /><label class="option-label">Trading</label>
                            <input type="checkbox" class="option-radio opt" name="nomineeoption" id="nomination-dp" value="DP" style="margin-left:6px;" /> <label class="option-label">DP</label>
                        </div>
                        <div class="col-md-6 offset-md-3" style="text-align:center">
                            <input type="checkbox" id="minornominee" style="width:11%" />
                            <span class="modif-text" style="font-size:12px">Nominee is Minor?</span>
                        </div>
                        <div class="col-md-12" style="display:none;" id="minornominee_div">
                            <div class="row">
                                <div class="col-md-12 inline-controls-text">
                                    <select class="form-control modif-text" id="guardianTitle" style="width:10% !important;padding:.1px !important">
                                        <option value="Mr.">Mr.</option>
                                        <option value="Ms.">Ms.</option>
                                    </select>
                                    <input type="text" id="txtGuardianName" class="form-control modif-text" placeholder="Guardian Name" style="width:35% !important;" />
                                    <input type="text" id="txtGuardianRelation" class="form-control modif-text" placeholder="Relation with Guardian" style="width:30% !important" />
                                </div>
                                <div class="col-md-12 inline-controls-text">
                                    <textarea class="form-control" placeholder="Guardian Address" id="txtGuardianAddress" style="width:87% !important"></textarea>
                                </div>
                                <div class="col-md-12 inline-controls-text">
                                    <input type="text" id="txtGuardianMobile" class="form-control modif-text" placeholder="Guardian Mobile" />
                                    <input type="text" id="txtGuardianEmail" class="form-control modif-text" placeholder="Guardian Email" />
                                </div>
                                <div class="col-md-12 inline-controls-text">
                                    <select class="form-control modif-text" id="guardianProofType">
                                        <option value="pan">PAN</option>
                                        <option value="aadhar">Aadhar</option>
                                    </select>
                                    <input type="file" id="file_guardianproof" class="form-control modif-text" placeholder="Guardian Proof" />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12" style="text-align:center">
                            <button class="btn btn-default" id="btnsubmit_nominee">Submit</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-Financial Updation-->
        <section class="change-section" style="margin-top:20px;margin-bottom:20px">
            <div class="row">
                <div class="col-md-12 expandedview">
                    <p class="expanded-p">Financial Updation</p>
                    <a href="#" class="btn btn-info option" id="fin">
                        <span class="fa fa-plus" style="font-size:30px;color:#ff6a00 !important"></span>
                    </a>
                </div>
                <div class="col-md-12 expanded-content" id="exp-fin">
                    <div class="row" id="divSubmit-fin">
                        <div class="col-md-12" style="text-align:center;">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="row">
                                        <div class="col-md-12" style="text-align:left;padding-bottom:10px">
                                            <span class="modif-text_" style="font-size:12px">Income Range</span>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="radio" name="incomerange" class="option-radio opt" id="below1lakh" value="Below1Lakh" /><label class="option-label">Below 1 Lakh</label>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="radio" name="incomerange" class="option-radio opt" id="oneto5lakh" value="1to5Lakh" /><label class="option-label">1-5 Lakh</label>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="radio" name="incomerange" class="option-radio opt" id="fiveto10lakh" value="5to10Lakh" /><label class="option-label">5-10 Lakh</label>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="radio" name="incomerange" class="option-radio opt" id="tento25lakh" value="10to25Lakh" /><label class="option-label">10-25 Lakh</label>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="radio" name="incomerange" class="option-radio opt" id="twentyfiveto1cr" value="25to1Cr" /><label class="option-label">25-1 Cr</label>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="radio" name="incomerange" class="option-radio opt" id="above1cr" value="Above1Cr" /><label class="option-label">Above 1 Cr</label>
                                        </div>
                                        <div class="col-md-2" style="text-align:left;padding-top:10px">
                                            <span class="modif-text_" style="font-size:12px">As on Date</span>
                                        </div>
                                        <div class="col-md-4" style="padding-bottom: 40px;padding-top:10px">
                                            <input type="date" id="incomedate" class="form-control" />
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-2">
                                    <span class="modif-text_" style="font-size:12px">Net Worth</span>
                                </div>
                                <div class="col-md-4">
                                    <input type="number" id="networth" class="form-control" />
                                </div>
                                <div class="col-md-2" style="text-align:left;">
                                    <span class="modif-text_" style="font-size:12px">As on Date</span>
                                </div>
                                <div class="col-md-4">
                                    <input type="date" id="networthdate" class="form-control" />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12" style="margin-top:10px">
                            <div class="row">
                                <div class="col-md-2">
                                    <span class="modif-text_" style="font-size:12px">Proof</span>
                                </div>
                                <div class="col-md-4">
                                    <select class="form-control" id="financial_proof">
                                        <option value="0">-Financial Proof-</option>
                                        <option value="Copy of ITR Acknowledgement">Copy of ITR Acknowledgement</option>
                                        <option value="Copy of Annual Accounts (For Corporates)">Copy of Annual Accounts (For Corporates)</option>
                                        <option value="Salary Slip or Form 16 (In case of Salary Income)">Salary Slip or Form 16 (In case of Salary Income)</option>
                                        <option value="NetWorth Certificates duly certified by Chartered Accountant">NetWorth Certificates duly certified by Chartered Accountant</option>
                                        <option value="Copy of Demat Holding Statement">Copy of Demat Holding Statement</option>
                                        <option value="Bank account Statement for last 6 months">Bank account Statement for last 6 months</option>
                                        <option value="Self-declaration along with relevant supporting documents">Self- declaration along with relevant supporting documents</option>
                                        <option value="DP Holdings">DP Holdings</option>
                                    </select>

                                </div>
                                <div class="col-md-2">
                                    <span class="modif-text_" style="font-size:12px">Upload File</span>
                                </div>
                                <div class="col-md-4">
                                    <input type="file" id="file_financialproof" class="form-control" placeholder="Financial Proof" />
                                </div>

                            </div>
                        </div>
                        <div class="col-md-12" style="text-align:center;margin-top:20px">
                            <button class="btn btn-default" id="btnsubmit_financial">Submit</button>
                        </div>


                    </div>
                </div>
            </div>
        </section>

        <!--Account Closure-->
        <section class="change-section" style="margin-top:20px;margin-bottom:20px;">
            <div class="row">
                <div class="col-md-12 expandedview">
                    <p class="expanded-p">Account Closure</p>
                    <a href="#" class="btn btn-info option" id="closure">
                        <span class="fa fa-plus" style="font-size:30px;color:#ff6a00 !important"></span>
                    </a>
                </div>
                <div class="col-md-12 expanded-content" id="exp-closure">
                    <div class="row" style="font-size:13px">
                        <div class="col-md-12"><p class="expanded-p-more">Request for Account Closure</p></div>
                        <div class="col-md-12 inline-controls">
                            <textarea type="text" class="form-control" style="width:90%" placeholder="Reason for Closure" id="txtreason" required></textarea>
                        </div>

                        <div class="col-md-12 inline-controls" style="justify-content:center;padding-bottom:30px;">
                            <input type="radio" id="havebalance" name="balance" class="option-radio" value="HAVE_BALANCE" /> <label class="option-label" style="margin-top:5px !important;padding:10px">Have Balance with Vertex</label>
                            <input type="radio" id="nobalance" name="balance" class="option-radio" value="HAVE_NO_BALANCE" /> <label class="option-label" style="margin-top:5px !important;padding:10px"> Have No Balance with Vertex</label>
                        </div>

                        <div class="col-md-12 inline-controls havebalance" style="display:none;">
                            <div class="row">
                                <div class="col-md-12" style="font-size:12px;color:red;text-decoration:underline">
                                    Specify how you want to keep your shares
                                </div>
                                <div class="col-md-12 inline-controls" style="font-size:12px;justify-content:space-around;padding-left:15px;padding-right:15px;">

                                    <input type="radio" id="transfer_ownaccount" name="sharetransfer" class="option-radio" value="TRANSFER_TO_MY_ACCOUNT" /><label class="option-label" style="margin-top:5px !important">Transfer to my Account</label>

                                    <input type="radio" id="transfer_anotheraccount" name="sharetransfer" class="option-radio" value="TRANSFER_TO_ANOTHER_ACCOUNT" /><label class="option-label" style="margin-top:5px !important">Transfer to any another Account</label>

                                    <input type="radio" id="remat" name="sharetransfer" class="option-radio" value="REMATERIALIZE" /><label class="option-label" style="margin-top:5px !important">Rematerialize / Reconvert Account</label>

                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 inline-controls transfer_ownaccount" style="display:none;border:1px solid #f3eaea">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="row">
                                        <div class="col-md-12" style="font-size:12px;color:red;text-align:center;text-decoration:underline">
                                            Target Account Details
                                        </div>
                                        <div class="col-md-6 offset-md-3 inline-controls" style="justify-content:space-around;font-size:12px">
                                            <p>Target Depository</p>
                                            <input type="radio" id="nsdl" name="depository" class="option-radio" value="NSDL" /> NSDL
                                            <input type="radio" id="cdsl" name="depository" class="option-radio" value="CDSL" /> CDSL
                                        </div>
                                        <div class="col-md-12 inline-controls" style="justify-content:space-around">
                                            <input type="text" placeholder="Target DP ID" id="targetdp" class="form-control" style="width:40%;" />
                                            <input type="text" placeholder="Target Client ID" id="targetclient" class="form-control" style="width:40%;" />
                                        </div>

                                        <div class="col-md-12 inline-controls" style="font-size:12px;justify-content:space-around">
                                            <p style="padding-top:10px;">Client master of Target account</p>
                                            <input type="file" placeholder="" id="cmfile" style="width:40%" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12" style="text-align:center;padding:20px" id="divSubmit-closure">
                            <button type="button" class="btn btn-default" id="btnSubmit-closure">Submit Request</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!--DDPI-->
        @{
            @*if (ViewBag.POA != null)
            {
                if ((int)ViewBag.POA != 1)
                {
                    <section class="change-section" style="margin-top:20px;margin-bottom:20px">
                        <div class="row">
